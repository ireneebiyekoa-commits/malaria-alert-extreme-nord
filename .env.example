# ============================================================
# Variables d'environnement - Système d'alerte paludisme
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Django ---
SECRET_KEY=remplacer-par-une-cle-secrete-aleatoire-de-50-caracteres-minimum
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Base de données ---
# Développement: SQLite (par défaut, pas besoin de DATABASE_URL)
# Production: PostgreSQL
# DATABASE_URL=postgres://user:password@host:5432/malaria_db

# --- API IA générative (Google Gemini - GRATUIT) ---
# Obtenir une clé sur : https://aistudio.google.com/app/apikey
# Tier gratuit : 15 requêtes/min, 1 500 requêtes/jour, 1 M tokens/min
GEMINI_API_KEY=votre_cle_gemini_ici
GEMINI_MODEL=gemini-2.5-flash

# --- API NASA POWER (données climatiques - GRATUIT, sans clé) ---
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/monthly/point

# --- Sécurité production ---
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
